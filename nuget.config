<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      This file scopes the NuGet sources to nuget.org only for this solution.
      This prevents authentication errors from any machine-level Telerik or
      private feed configurations.
    -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
